// TaskFlow - Task Manager + Notes Manager
// Document-oriented SQLite with JSON metadata fields

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  oidcId       String?  @unique
  oidcProvider String?
  metadata     String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedAreas    Area[]
  ownedProjects Project[]
  ownedTasks    Task[]
  ownedNotes    Note[]
  ownedFolders  NoteFolder[]
  assignedTasks Task[]    @relation("TaskAssignee")
  comments      Comment[]
  tags          Tag[]
  webhooks      Webhook[]
  scheduledJobs ScheduledJob[]
  fileBlobs     FileBlob[]
  attachments   Attachment[]
}

model Area {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String   @default("#6366f1")
  icon            String?
  metadata        String   @default("{}")
  tagIds          String   @default("[]")
  shortIdNum      Int      @default(0)
  ownerId         String
  sortOrder       Int      @default(0)
  visibility      String?
  visibleUserIds  String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  projects Project[]
}

model Project {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String   @default("#8b5cf6")
  icon            String?
  status          String   @default("active")
  metadata        String   @default("{}")
  tagIds          String   @default("[]")
  shortIdNum      Int      @default(0)
  areaId          String?
  ownerId         String
  sortOrder       Int      @default(0)
  visibility      String?
  visibleUserIds  String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  area    Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  owner   User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks   Task[]
  notes   Note[]
  folders NoteFolder[]
}

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String?
  status          String    @default("todo")
  priority        String    @default("medium")
  dueDate         DateTime?
  assigneeId      String?
  projectId       String?
  parentId        String?
  metadata        String    @default("{}")
  tagIds          String    @default("[]")
  shortIdNum      Int       @default(0)
  sortOrder       Int       @default(0)
  ownerId         String
  visibility      String?
  visibleUserIds  String    @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent     Task?     @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks   Task[]    @relation("TaskHierarchy")
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  assignee   User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments   Comment[]
}

model Note {
  id              String   @id @default(cuid())
  title           String
  content         String   @default("")
  projectId       String?
  folderId        String?
  metadata        String   @default("{}")
  tagIds          String   @default("[]")
  shortIdNum      Int      @default(0)
  ownerId         String
  sortOrder       Int      @default(0)
  visibility      String?
  visibleUserIds  String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  folder  NoteFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  owner   User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model NoteFolder {
  id              String   @id @default(cuid())
  name            String
  projectId       String?
  parentId        String?
  metadata        String   @default("{}")
  shortIdNum      Int      @default(0)
  ownerId         String
  sortOrder       Int      @default(0)
  visibility      String?
  visibleUserIds  String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent    NoteFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  NoteFolder[] @relation("FolderHierarchy")
  notes     Note[]
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner     User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  ownerId   String
  parentId  String?
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  owner    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parent   Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([name, ownerId])
}

model Webhook {
  id           String   @id @default(cuid())
  name         String
  url          String
  method       String   @default("POST")
  headers      String   @default("{}")
  bodyTemplate String?
  active       Boolean  @default(true)
  ownerId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner      User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]
  triggers   WebhookTrigger[]
}

model WebhookTrigger {
  id        String   @id @default(cuid())
  webhookId String
  events    String   @default("[]")
  scopeType String?
  scopeId   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    String   @default("{}")
  statusCode Int?
  response   String?
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

model ScheduledJob {
  id         String   @id @default(cuid())
  type       String
  fireAt     DateTime
  entityId   String
  entityType String   @default("task")
  ownerId    String
  payload    String   @default("{}")
  createdAt  DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model FileBlob {
  id           String   @id @default(cuid())
  hash         String   @unique
  size         Int
  mimeType     String
  originalName String
  storageKey   String
  ownerId      String
  createdAt    DateTime @default(now())

  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([hash])
}

model Attachment {
  id          String   @id @default(cuid())
  entityId    String
  entityType  String
  blobId      String
  displayName String?
  ownerId     String
  createdAt   DateTime @default(now())

  blob  FileBlob @relation(fields: [blobId], references: [id], onDelete: Cascade)
  owner User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([entityId, entityType, blobId])
  @@index([entityId, entityType])
}
