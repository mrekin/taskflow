# Copy this file to docker-compose.yml and adjust values.
# Sensitive values should be set via .env file (see .env.example).

services:
  taskflow:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        NEXT_BASE_PATH: ${NEXT_BASE_PATH:-}
        BUILD_TYPE: ${BUILD_TYPE:-test}          # test|dev|release
    container_name: taskflow
    restart: unless-stopped
    ports:
      - "${PORT:-3000}:3000"
    environment:
      # --- Required ---
      - NOAUTH_MODE=${NOAUTH_MODE:-true}
      - NODE_ENV=production
      - BUILD_TYPE=${BUILD_TYPE:-test}
      - DATABASE_URL=${DATABASE_URL:-file:/app/db/taskflow.db}
      - NEXTAUTH_URL=${NEXTAUTH_URL}
      - NEXTAUTH_SECRET=${NEXTAUTH_SECRET}
      - SCHEDULER_INTERVAL_MIN=${SCHEDULER_INTERVAL_MIN:-1}
      # --- OIDC / SSO ---
      # - OIDC_ISSUER=${OIDC_ISSUER}
      # - OIDC_CLIENT_ID=${OIDC_CLIENT_ID}
      # - OIDC_CLIENT_SECRET=${OIDC_CLIENT_SECRET}
      # --- Kanban columns (default for all users) ---
      # - KANBAN_COLUMNS=${KANBAN_COLUMNS}
      # --- Attachments ---
      # - ATTACHMENT_MAX_SIZE=${ATTACHMENT_MAX_SIZE:-10485760}
      # - ATTACHMENT_MAX_PER_ENTITY=${ATTACHMENT_MAX_PER_ENTITY:-10}
      # - ATTACHMENT_ALLOWED_PATTERNS=${ATTACHMENT_ALLOWED_PATTERNS:-*}
      # - STORAGE_ADAPTER=${STORAGE_ADAPTER:-local}
      # - STORAGE_LOCAL_PATH=${STORAGE_LOCAL_PATH:-/app/uploads}
      # --- Demo mode (mutually exclusive with NOAUTH_MODE and OIDC) ---
      # - DEMO_MODE=${DEMO_MODE:-false}
      # - DEMO_RESET_MIN=${DEMO_RESET_MIN:-15}
    volumes:
      - ./taskflow-data:/app/db
      - ./taskflow-files:/app/uploads
