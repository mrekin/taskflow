# === TaskFlow Configuration ===
# See README.md for full documentation.

# --- Required ---
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=file:/app/db/taskflow.db

# --- App ---
PORT=3000
NOAUTH_MODE=true
# BUILD_TYPE=test|dev|release

# --- Subpath (build-time, for reverse proxy) ---
# NEXT_BASE_PATH=/taskflow

# --- Scheduler ---
# SCHEDULER_INTERVAL_MIN=1

# --- Kanban columns (default for all users) ---
# KANBAN_COLUMNS=To Do:#94a3b8,In Progress:#3b82f6,Review:#f59e0b,Done:#22c55e,Cancelled:#ef4444

# --- OIDC / SSO ---
# OIDC_ISSUER=https://your-keycloak.com/realms/your-realm
# OIDC_CLIENT_ID=taskflow
# OIDC_CLIENT_SECRET=your-client-secret

# --- Demo mode (mutually exclusive with NOAUTH_MODE and OIDC) ---
# DEMO_MODE=false
# DEMO_RESET_MIN=15

# --- Attachments ---
# ATTACHMENT_MAX_SIZE=10485760
# ATTACHMENT_MAX_PER_ENTITY=10
# ATTACHMENT_MAX_PER_COMMENT=3
# ATTACHMENT_ALLOWED_PATTERNS=*
# ATTACHMENT_TOTAL_SIZE=0
# ATTACHMENT_USER_MAX_SIZE=512
# STORAGE_ADAPTER=local
# STORAGE_LOCAL_PATH=/app/uploads
